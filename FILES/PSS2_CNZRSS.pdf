										<code code="024840074" codeSystem="2.16.840.1.113883.2.9.6.1.5" codeSystemName="AIC" displayName="CARDIOASPIRIN*100 MG COMPRESSE GASTRORESISTENTI-30 COMPRESSE">
										</code>
