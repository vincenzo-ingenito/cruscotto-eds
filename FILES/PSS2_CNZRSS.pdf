			<component typeCode="COMP">
				<section ID="TERAPIE_FARMACOLOGICHE">
					<templateId root="2.16.840.1.113883.2.9.10.1.4.2.2"/>
					<id root="XXX"/>
					<code code='10160-0' codeSystem='2.16.840.1.113883.6.1' codeSystemName='LOINC' displayName='HISTORY OF MEDICATION USE'/>
					<title>Terapie Farmacologiche</title>
					<text>
						[NARRATIVE_BLOCK]
					</text>
					<entry>
						<substanceAdministration classCode="SBADM" moodCode="EVN">
							<templateId root="2.16.840.1.113883.2.9.10.1.4.3.2.1"/>
							<id root="XXX"/>
							<text>
								<reference value="#[REF_MED]"/>
							</text>
							<statusCode code="completed"/>
							<effectiveTime xsi:type="IVL_TS">
								<low value="20260101000000+0100"/>
								<high value="20261201000000+0100"/>
							</effectiveTime>
							<effectiveTime operator="A" xsi:type="PIVL_TS" institutionSpecified="true">
								<period value="6" unit="h" />
							</effectiveTime>
							<!--Via di somministrazione (OPZIONALE)-->
							<routeCode code="SQ" codeSystem="2.16.840.1.113883.5.112" codeSystemName="HL7 RouteOfAdministration" displayName="Injection, subcutaneous"/>
							<!--Sito di somministrazione (OPZIONALE)-->
							<approachSiteCode code="LA" codeSystem="2.16.840.1.113883.5.1052" codeSystemName="ActSite" displayName="left arm"/>
							<!--Dose (OPZIONALE)-->
							<doseQuantity>
								<low value="2" unit="mg"/>
								<high value="3" unit="mg"/> 
							</doseQuantity>
							<!--Frequenza di erogazione (OPZIONALE)-->
							<rateQuantity>
								<low value="20" unit="mL/min"/>
								<high value="50" unit="mL/min"/> 
							</rateQuantity>
							<!-- ATC / AIC / GE-->
							<consumable>
								<manufacturedProduct classCode="MANU">
							<!--Dettagli del Farmaco-->
									<templateId root="2.16.840.1.113883.2.9.10.1.4.3.2.2"/>
									<manufacturedMaterial>
										<templateId root="2.16.840.1.113883.10.22.4.3"/>
										<code code="024840074" codeSystem="2.16.840.1.113883.2.9.6.1.5" codeSystemName="AIC" displayName="CARDIOASPIRIN*100 MG COMPRESSE GASTRORESISTENTI-30 COMPRESSE">
											<originalText>
												<reference value='#[REF_FARM]'/>
											</originalText>
											<translation code="B01AC06" codeSystem="2.16.840.1.113883.6.73" codeSystemName="ATC" displayName="Acido acetilsalicilico"/>
										</code>
